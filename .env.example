# Local development only. Never commit a real .env file.
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/online_art_gallery
JWT_SECRET=replace-this-with-a-long-random-secret
CLIENT_ORIGIN=http://localhost:5173
NODE_ENV=development

# Vercel production requires only MONGODB_URI and JWT_SECRET.
# Keep VITE_API_URL unset because the frontend and API share one domain.
